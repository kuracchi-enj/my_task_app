# 開発環境専用 Dockerfile
# 本番環境には Dockerfile を使用すること

ARG RUBY_VERSION=3.4.3
FROM docker.io/library/ruby:$RUBY_VERSION

# Node.js 22 LTS インストール
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install --no-install-recommends -y nodejs \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# PostgreSQL クライアント（db:create 等で必要）
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y postgresql-client libpq-dev && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Gemfile を先にコピーしてキャッシュを活用
COPY Gemfile Gemfile.lock ./
RUN bundle install

# package.json が存在する場合は npm install
COPY package*.json ./
RUN npm install

COPY . .

# エントリポイントスクリプト
COPY entrypoint.sh /usr/bin/entrypoint.sh
RUN chmod +x /usr/bin/entrypoint.sh

EXPOSE 3000

ENTRYPOINT ["entrypoint.sh"]
CMD ["bundle", "exec", "rails", "server", "-b", "0.0.0.0"]
