<% content_for :title, "ログイン | My Task App" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center">
  <div class="w-full max-w-sm bg-white rounded-lg shadow-sm border p-8">
    <h1 class="text-xl font-bold text-gray-900 mb-6 text-center">My Task App</h1>

    <% if flash[:alert] %>
      <div class="mb-4 p-3 text-sm text-red-700 bg-red-50 border border-red-200 rounded">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, class: "flex flex-col gap-4" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="login_id">ユーザーID</label>
        <%= f.text_field :login_id, id: "login_id", autocomplete: "username",
              class: "w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
              placeholder: "ユーザーID" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="password">パスワード</label>
        <%= f.password_field :password, id: "password", autocomplete: "current-password",
              class: "w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
              placeholder: "パスワード" %>
      </div>

      <%= f.submit "ログイン",
            class: "w-full py-2 px-4 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
